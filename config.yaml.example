# VibeCodingBot Configuration
# Copy this file to config.yaml and fill in your values

telegramBotToken: your_bot_token_here
logLevel: info

# 可选：worktree 存放目录
# 不设置则使用仓库的父目录
worktreeBaseDir: ~/Personal/worktrees

commands:
  - name: research
    dir: ~/workspace/research
    prompt: /opsx:propose
    session: research-bot
    model: opencode/glm-4.7-free
    # 新增配置项
    maxConcurrent: 3        # 最大并发任务数，默认 3
    prMergeStrategy: manual # PR 合并策略: manual | auto

cronTasks:
  - name: daily-research
    schedule: "0 9 * * *"
    command: research
    chatId: 123456789
    enabled: true
