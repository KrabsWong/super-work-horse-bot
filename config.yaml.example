# VibeCodingBot Configuration
# Multi-platform bot supporting Telegram and Discord

# =============================================================================
# Platform Configuration
# =============================================================================

platforms:
  # Which platform to use: 'telegram' or 'discord'
  activePlatform: telegram

  # Telegram configuration
  telegram:
    token: your_telegram_bot_token_here

  # Discord configuration
  discord:
    token: your_discord_bot_token_here

# =============================================================================
# Bot Settings
# =============================================================================

logLevel: info

# Base directory for git worktrees (optional, defaults to parent of repo)
# worktreeBaseDir: ~/workspace/worktrees

# =============================================================================
# Commands Configuration
# =============================================================================

commands:
  - name: research
    # Working directory for this command
    dir: ~/workspace/research
    # Prompt prefix sent to opencode
    prompt: /opsx:propose
    # tmux session name prefix
    session: research-bot
    # AI model to use (optional)
    model: opencode/glm-4.7-free
    # Maximum concurrent tasks for this command
    maxConcurrent: 3

  # Example: Add more commands
  # - name: dev
  #   dir: ~/workspace/dev
  #   prompt: /opsx:propose
  #   session: dev-bot
  #   model: opencode/glm-4.7-free
  #   maxConcurrent: 2

# =============================================================================
# Scheduled Tasks (Cron Tasks)
# =============================================================================
#
# Scheduled tasks are now configured via Markdown files in the cron/ directory.
# Each .md file represents a scheduled task with YAML frontmatter.
#
# Example cron/daily-research.md:
# ---
# name: daily-research
# schedule: 每天 09:00
# messenger: telegram
# enabled: true
# ---
#
# 每天早上9点，从 GitHub trending 中选择一个热门项目，
# 进行深入研究分析，生成研究报告。
#
# Supported schedule formats:
# - "每天 HH:MM" - Every day at specific time
# - "每周一 HH:MM" - Every Monday
# - "工作日 HH:MM" - Weekdays only (Mon-Fri)
# - "每周末 HH:MM" - Weekends only
# - "每小时" - Every hour
# - "每N小时" - Every N hours
# - Standard cron expression: "0 9 * * *"

# =============================================================================
# Getting Platform Tokens
# =============================================================================

# Telegram Bot Token:
# 1. Open https://t.me/botfather
# 2. Send /newbot and follow instructions
# 3. Copy the token

# Discord Bot Token:
# 1. Go to https://discord.com/developers/applications
# 2. Create a new application
# 3. Navigate to "Bot" section
# 4. Click "Add Bot"
# 5. Enable "Message Content Intent" under Privileged Gateway Intents
# 6. Copy the token
# 7. Invite bot using: 
#    https://discord.com/api/oauth2/authorize?client_id=YOUR_CLIENT_ID&permissions=2048&scope=bot